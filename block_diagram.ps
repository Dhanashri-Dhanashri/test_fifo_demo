<< /PageSize [1920 1080] >> setpagedevice

% ---------- Helpers ----------
/box {
  % x y w h r g b
  /b exch def /g exch def /r exch def
  /h exch def /w exch def /y exch def /x exch def
  gsave
  r g b setrgbcolor
  newpath x y moveto w 0 rlineto 0 h rlineto w neg 0 rlineto closepath fill
  grestore
} def

/border {
  % x y w h lw r g b
  /b exch def /g exch def /r exch def /lw exch def
  /h exch def /w exch def /y exch def /x exch def
  gsave
  lw setlinewidth
  r g b setrgbcolor
  newpath x y moveto w 0 rlineto 0 h rlineto w neg 0 rlineto closepath stroke
  grestore
} def

/node {
  % x y w h fillR fillG fillB borderR borderG borderB
  /bb exch def /bg exch def /br exch def
  /fb exch def /fg exch def /fr exch def
  /h exch def /w exch def /y exch def /x exch def
  x y w h fr fg fb box
  x y w h 2 br bg bb border
} def

/txt {
  % x y size r g b (text)
  /t exch def /b exch def /g exch def /r exch def /sz exch def /y exch def /x exch def
  gsave
  /Helvetica findfont sz scalefont setfont
  r g b setrgbcolor
  x y moveto t show
  grestore
} def

/txtb {
  % x y size r g b (text)
  /t exch def /b exch def /g exch def /r exch def /sz exch def /y exch def /x exch def
  gsave
  /Helvetica-Bold findfont sz scalefont setfont
  r g b setrgbcolor
  x y moveto t show
  grestore
} def

/arrow {
  % x1 y1 x2 y2 lw r g b
  /b exch def /g exch def /r exch def /lw exch def
  /y2 exch def /x2 exch def /y1 exch def /x1 exch def
  gsave
  lw setlinewidth
  r g b setrgbcolor
  newpath x1 y1 moveto x2 y2 lineto stroke
  /dx x2 x1 sub def
  /dy y2 y1 sub def
  /ang dy dx atan def
  x2 y2 translate ang rotate
  newpath 0 0 moveto -12 6 lineto -12 -6 lineto closepath fill
  grestore
} def

/linklbl {
  % x y (text)
  /t exch def /y exch def /x exch def
  x y 10 0.73 0.77 0.83 t txt
} def

